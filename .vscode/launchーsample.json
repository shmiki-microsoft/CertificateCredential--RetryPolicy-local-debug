{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH":"your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD" :"your certificate password",
                "endpoint": "https://graph.microsoft.com/v1.0/users",
                "DEBUG_PROXY": "0"
                }
        },
        {
            "name": "Python: main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH":"your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD" :"your certificate password",
                "endpoint": "https://graph.microsoft.com/v1.0/users",
                "DEBUG_PROXY": "http://127.0.0.1:3128"
                }
        },
        {
            "name": "Python: main_simple.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_simple.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH":"your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD" :"your certificate password",
                "endpoint": "https://graph.microsoft.com/v1.0/users",
                "DEBUG_PROXY": "0"
                }
        },
        {
            "name": "Python: main_no_retry.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main_no_retry.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH":"your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD" :"your certificate password",
                "endpoint": "https://graph.microsoft.com/v1.0/users",
                "DEBUG_PROXY": "0"
                }
        },
        {
            "name": "verify: ① default (retry/timeout なし)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/verify.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH": "your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD": "your certificate password",
                "PATTERN": "default",
                "TARGET": "both",
                "DEBUG_PROXY": "0"
                }
        },
        {
            "name": "verify: ② timeout のみ",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/verify.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH": "your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD": "your certificate password",
                "PATTERN": "timeout",
                "TARGET": "both",
                "DEBUG_PROXY": "http://127.0.0.1:3128",
                "AZURE_CONNECTION_TIMEOUT": "30",
                "AZURE_READ_TIMEOUT": "60",
                "HTTPX_CONNECT": "30",
                "HTTPX_READ": "60",
                "HTTPX_WRITE": "60",
                "HTTPX_POOL": "5"
                }
        },
        {
            "name": "verify: ③ retry のみ",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/verify.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH": "your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD": "your certificate password",
                "PATTERN": "retry",
                "TARGET": "both",
                "DEBUG_PROXY": "http://127.0.0.1:3128",
                "AZURE_RETRY_TOTAL": "4",
                "AZURE_RETRY_CONNECT": "4",
                "AZURE_RETRY_READ": "4",
                "AZURE_RETRY_BACKOFF_FACTOR": "20",
                "AZURE_RETRY_BACKOFF_MAX": "20",
                "GRAPH_MAX_RETRIES": "4",
                "GRAPH_DELAY": "5",
                "GRAPH_MANUAL_MAX_ATTEMPTS": "4",
                "GRAPH_MANUAL_BACKOFF_FACTOR": "20",
                "GRAPH_MANUAL_BACKOFF_MAX": "20"
                }
        },
        {
            "name": "verify: ④ both (retry+timeout)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/verify.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "AZURE_CLIENT_ID": "your_client_id",
                "AZURE_TENANT_ID": "your_tenant_id",
                "AZURE_CLIENT_CERTIFICATE_PATH": "your certificate path",
                "AZURE_CLIENT_CERTIFICATE_PASSWORD": "your certificate password",
                "PATTERN": "both",
                "TARGET": "both",
                "DEBUG_PROXY": "http://127.0.0.1:3128",
                "AZURE_CONNECTION_TIMEOUT": "30",
                "AZURE_READ_TIMEOUT": "60",
                "HTTPX_CONNECT": "30",
                "HTTPX_READ": "60",
                "HTTPX_WRITE": "60",
                "HTTPX_POOL": "5",
                "AZURE_RETRY_TOTAL": "4",
                "AZURE_RETRY_CONNECT": "4",
                "AZURE_RETRY_READ": "4",
                "AZURE_RETRY_BACKOFF_FACTOR": "20",
                "AZURE_RETRY_BACKOFF_MAX": "20",
                "GRAPH_MAX_RETRIES": "4",
                "GRAPH_DELAY": "5",
                "GRAPH_MANUAL_MAX_ATTEMPTS": "4",
                "GRAPH_MANUAL_BACKOFF_FACTOR": "20",
                "GRAPH_MANUAL_BACKOFF_MAX": "20"
                }
        }
    ]
}